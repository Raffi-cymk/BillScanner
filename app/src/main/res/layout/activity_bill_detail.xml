<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#777CE3">

    <!-- Tombol Kembali -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kembali"
        android:textAllCaps="false"
        android:fontFamily="serif"
        android:backgroundTint="@android:color/white"
        android:textColor="@android:color/black"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Judul -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detail Tagihan"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nama -->
    <TextView
        android:id="@+id/tvNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="40dp"/>

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Raffi Pasha"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
        app:layout_constraintStart_toStartOf="@id/tvNameLabel"
        android:layout_marginTop="8dp"/>

    <!-- Jumlah -->
    <TextView
        android:id="@+id/tvAmountLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jumlah Tagihan"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvName"
        app:layout_constraintStart_toStartOf="@id/tvName"/>

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rp 250.000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/tvAmountLabel"
        app:layout_constraintStart_toStartOf="@id/tvAmountLabel"
        android:layout_marginTop="8dp"/>

    <!-- Tanggal -->
    <TextView
        android:id="@+id/tvDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tanggal"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvAmount"
        app:layout_constraintStart_toStartOf="@id/tvAmount"/>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hari ini"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/tvDateLabel"
        app:layout_constraintStart_toStartOf="@id/tvDateLabel"
        android:layout_marginTop="8dp"/>

    <!-- Tombol Bayar -->
    <Button
        android:id="@+id/btnPay"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Bayar"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:fontFamily="serif"
        android:backgroundTint="@android:color/white"
        android:textColor="@android:color/black"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/tvAmount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>